# Copy to .env and fill in. The API reads these at startup.

# Port the API listens on (must match the Vite proxy in vite.config.js).
PORT=3001

# Who gets notified on every order. Each entry is "number:carrier",
# comma-separated. We email the carrier's email-to-SMS gateway so the message
# arrives as a text. Supported carriers: tmobile, verizon.
# Required even in console mode (real values are fine there — nothing sends).
ORDER_NOTIFY_RECIPIENTS=+19193490461:tmobile,+15555550101:verizon,+15555550102:verizon

# Transport: "email" (real texts via email-to-SMS) or "console" (prints to log).
# Leave unset to auto-pick: email if the SMTP creds below are all present, else console.
# NOTIFY_TRANSPORT=console

# SMTP credentials (only needed for real sends). For Gmail, use an App Password
# (Google Account → Security → App passwords), not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=you@gmail.com
